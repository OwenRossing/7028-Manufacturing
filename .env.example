# Set to "demo" to enable demo login (bypasses Google auth, allows HTTP cookies)
# Set to "local" to enable LAN mode: entry key + user picker, no Google required
APP_MODE="production"

# Required when APP_MODE=local. Shared key teammates enter to access the user list.
LOCAL_ENTRY_KEY=""

# Use localhost when running npm directly; use "db" for container-to-container.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/frc_parts?schema=public"

# OAuth 2.0 client ID from https://console.cloud.google.com
# Leave empty to disable Google sign-in entirely.
GOOGLE_CLIENT_ID=""

# Comma-separated list of email addresses with admin privileges.
ADMIN_EMAILS=""

# "local" stores uploads in public/uploads/. "s3" requires the vars below.
STORAGE_DRIVER="local"

# Required when STORAGE_DRIVER=s3. Public base URL for serving stored files.
NEXT_PUBLIC_STORAGE_PUBLIC_BASE_URL=""
STORAGE_KEY_PREFIX="parts-media"

# S3-compatible storage credentials (only needed when STORAGE_DRIVER=s3)
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"

# API keys from https://dev-portal.onshape.com — leave empty to disable.
ONSHAPE_ACCESS_KEY=""
ONSHAPE_SECRET_KEY=""
# Defaults to https://cad.onshape.com — only override for enterprise instances.
# ONSHAPE_BASE_URL="https://cad.onshape.com"

# MAX_UPLOAD_MB="10"
# SESSION_TTL_SECONDS="1209600"
