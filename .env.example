APP_MODE="production"
NEXT_PUBLIC_APP_MODE="production"
# Local/dev connection string (for host tooling use localhost, not db).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/frc_parts?schema=public"
# Optional explicit production DB URL (used when APP_MODE=production).
DATABASE_URL_PRODUCTION="postgresql://<user>:<password>@<prod-host>:5432/<db>?schema=public"
NEXT_PUBLIC_APP_NAME="FRC Parts Tracker"
DEMO_SESSION_COOKIE="demo_session_id"
MAX_UPLOAD_MB="10"
SESSION_TTL_SECONDS="1209600"
AUTH_COOKIE_SECURE=""
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
ADMIN_EMAILS=""
STORAGE_DRIVER="local"
# Public base URL for stored media (required for object storage)
STORAGE_PUBLIC_BASE_URL=""
NEXT_PUBLIC_STORAGE_PUBLIC_BASE_URL=""
STORAGE_KEY_PREFIX="parts-media"
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"
ONSHAPE_BASE_URL="https://cad.onshape.com"
ONSHAPE_ACCESS_KEY=""
ONSHAPE_SECRET_KEY=""
