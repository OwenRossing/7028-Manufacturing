{
  "name": "frc-parts-tracker-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "start": "node scripts/start.mjs",
    "ci:offline": "npm run lint && npm run typecheck:offline && npm run build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "next typegen && tsc --noEmit",
    "typecheck:offline": "next typegen && tsc --noEmit",
    "credential-test": "tsx scripts/credential-test.ts",
    "prisma:generate": "prisma generate",
    "prisma:generate:if-present": "node scripts/prisma-generate-if-present.cjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force --skip-generate && npm run prisma:seed",
    "create-user": "tsx scripts/create-user.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@prisma/client": "^6.2.1",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-virtual": "^3.13.23",
    "clsx": "^2.1.1",
    "lucide-react": "^0.473.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  }
}
